# Database
DATABASE_URL=postgres://fcl:localdev@localhost:5441/compliance_ledger

# NATS
NATS_URL=nats://localhost:4222
NATS_TOKEN=xxxxx
NATS_SUBJECT=recon.discrepancy.detected
NATS_CONSUMER_NAME=compliance-ledger

# Server
PORT=8080
LOG_LEVEL=info

# Notification Hub (off by default — standalone mode)
NOTIFICATION_HUB_URL=https://notify.kingsleyonoh.com
NOTIFICATION_HUB_API_KEY=xxxxx
NOTIFICATION_HUB_ENABLED=false

# RAG Platform (off by default — standalone mode)
RAG_PLATFORM_URL=https://ai.kingsleyonoh.com
RAG_PLATFORM_API_KEY=xxxxx
RAG_FEED_ENABLED=false

# Escalation
ESCALATION_INTERVAL_MINUTES=15
MAX_NOTIFICATION_RETRIES=3

# Tenant Management
SELF_REGISTRATION_ENABLED=true

# Reports
REPORT_STORAGE_PATH=data/reports
REPORT_MAX_EVENTS=10000
